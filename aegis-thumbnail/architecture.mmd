      WAH["/api/whatsapp<br/>webhook"]
      AUTH["/api/auth"]
    end
    AGENT["Mastra Agent (in-process via AI SDK)<br/>tools: searchVault, readDocument,<br/>getDocumentLink, getReminders, getContacts"]
