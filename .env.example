# Copy to .env.local and fill in. Do not commit .env.local.

# Postgres connection string (Aurora Serverless v2 / Neon / local Postgres).
# Local Docker:  postgresql://aegis:aegis@localhost:5433/aegis
# Aurora:        postgresql://<master_user>:<password>@<cluster-endpoint>:5432/<db>
DATABASE_URL=

# TLS for the Postgres connection. Local Docker speaks plaintext; Aurora requires TLS.
#   disable  -> no TLS (local dev, the default if unset)
#   require  -> TLS without CA verification (quickest Aurora path)
#   verify   -> TLS + verify against the RDS CA bundle in DATABASE_SSL_CA
DATABASE_SSL=disable
# Path to the AWS RDS global CA bundle PEM, only used when DATABASE_SSL=verify.
# Download: https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
DATABASE_SSL_CA=

# Better Auth secret used to sign sessions. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL of the running app.
BETTER_AUTH_URL=http://localhost:3000

# Object storage for uploaded documents.
# Driver: 'r2' (default) or 'local' (writes to ./uploads for dev without creds).
STORAGE_DRIVER=r2
# Cloudflare R2 (S3-compatible). Endpoint = https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public bucket domain (pub-xxx.r2.dev or a custom domain). Used for document links.
R2_PUBLIC_URL=

# Mastra agent — LLM provider. Mastra's model router auto-detects this key.
ANTHROPIC_API_KEY=
# Model string for the router (override to bump, e.g. anthropic/claude-opus-4-8).
LLM_MODEL=anthropic/claude-sonnet-4-6

# Standalone Mastra server (pnpm mastra:dev). Browser talks to it via client-js.
NEXT_PUBLIC_MASTRA_URL=http://localhost:4111
WEB_ORIGIN=http://localhost:3000
MASTRA_PORT=4111

# Telegram channel. Local dev: `pnpm telegram` (long-poll worker, no public URL).
# Production: register the webhook with `pnpm telegram:webhook <prod-url>` so
# Telegram POSTs to /api/telegram (no always-on process needed).
# Create a bot with @BotFather to get the token; username drives t.me deep-links.
TELEGRAM_BOT_TOKEN=
# Bot username without the @ (e.g. AegisVaultBot). Exposed to the app for deep-links.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
# Webhook shared secret — Telegram echoes it back and the route verifies it.
# Generate with: openssl rand -hex 32  (only used by the production webhook).
TELEGRAM_WEBHOOK_SECRET=
